{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "miro/shared/contracts/simulation-files.request.schema.json",
  "title": "SimulationFilesRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "files"
  ],
  "properties": {
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fileName",
          "contentType",
          "sizeBytes"
        ],
        "properties": {
          "fileName": {
            "type": "string"
          },
          "contentType": {
            "type": "string"
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 0
          },
          "sourceType": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
