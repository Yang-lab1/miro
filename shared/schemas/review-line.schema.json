{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "miro/shared/schemas/review-line.schema.json",
  "title": "ReviewLine",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lineIndex",
    "speaker",
    "turnIndex",
    "text",
    "alertIssueKeys",
    "createdAt"
  ],
  "properties": {
    "lineIndex": {
      "type": "integer",
      "minimum": 1
    },
    "speaker": {
      "type": "string",
      "enum": [
        "user",
        "assistant"
      ]
    },
    "turnIndex": {
      "type": "integer",
      "minimum": 1
    },
    "text": {
      "type": "string"
    },
    "alertIssueKeys": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
