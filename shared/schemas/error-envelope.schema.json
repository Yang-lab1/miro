{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "miro/shared/schemas/error-envelope.schema.json",
  "title": "ErrorEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "error",
    "requestId"
  ],
  "properties": {
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "details"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "object"
        }
      }
    },
    "requestId": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
