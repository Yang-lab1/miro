{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "miro/shared/schemas/billing-account.schema.json",
  "title": "BillingAccount",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "currentPlanKey",
    "creditBalance",
    "renewalAt",
    "currencyCode"
  ],
  "properties": {
    "currentPlanKey": {
      "type": "string",
      "enum": [
        "free",
        "go",
        "plus",
        "pro"
      ]
    },
    "creditBalance": {
      "type": "integer",
      "minimum": 0
    },
    "renewalAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "currencyCode": {
      "type": "string"
    }
  }
}
