APP_NAME=miro-backend
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173"]
FRONTEND_SITE_URL=
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/miro
DATABASE_ECHO=false
ENABLE_DOCS=true
SUPABASE_URL=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_URL=
ALLOW_DEMO_ACTOR_FALLBACK=false
DEMO_USER_EMAIL=demo@miro.local
REALTIME_PROVIDER_MODE=stub
